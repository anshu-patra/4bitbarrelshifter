@file(run_modus_atpg.tcl) 93: if {$do_build_testmode_FULLSCAN} {
    puts "\n>>> Building test mode: $TESTMODE ..."
    if {$MODEDEF ne ""} {
        build_testmode \
            -workdir  $WORKDIR    \
            -testmode $TESTMODE   \
            -modedef  $MODEDEF    \
            -assignfile $ASSIGNFILE
    } else {
        # Fall back: no modedef (Modus infers from netlist scan annotations)
        build_testmode \
            -workdir    $WORKDIR    \
            -testmode   $TESTMODE   \
            -assignfile $ASSIGNFILE
    }
}

